{
  "tasks": {
    "install": "cd client && npm install",
    "dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build-tiles": "deno run --allow-read --allow-write --allow-run=magick scripts/build_tiles.ts",
    "serve": "deno run --allow-net --allow-read --allow-env --allow-run=magick server.ts",
    "start": "deno task build && deno task serve",
    "run": "deno run --allow-read --allow-write --allow-env --allow-net=imagemagick.org --allow-run=deno scripts/run.ts"
  },
  "fmt": {
    "include": ["server.ts"]
  }
}
