# Lovely Labels — runtime configuration.
#
#   cp .env.example .env   # then tweak the values below
#
# The local `deno task serve|start|build-tiles|run` commands load this file
# via Deno's --env-file flag (.env is gitignored). It is NOT used by Docker /
# Render: there the values are injected directly (docker-compose.yml env block,
# render.yaml envVars / dashboard). So .env only matters for non-Docker dev.

# Port the Deno server listens on. Render injects its own value at runtime.
PORT=8080

# Path or name of the ImageMagick binary used for server-rendered text and
# tile resizing. Inside the Docker image this is symlinked from
# /usr/bin/convert (ImageMagick 6 on Debian).
MAGICK_BIN=magick
